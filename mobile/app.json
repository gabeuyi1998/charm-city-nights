{
  "expo": {
    "name": "Charm City Nights",
    "slug": "charm-city-nights",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "charmcitynights",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gabe.charmcitynights"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA"
      ],
      "package": "com.gabe.charmcitynights"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Charm City Nights to access your camera to capture moments at your favorite venues."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Charm City Nights to use your location to find nearby bars and check in."
        }
      ],
      ["@rnmapbox/maps", { "RNMapboxMapsDownloadToken": "" }]
    ]
  }
}
